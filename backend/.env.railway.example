# ===== APIHarbor — Railway service variables (set these in the Railway dashboard) =====
# This is a REFERENCE ONLY (safe to commit — contains no real secrets).
# In Railway, add these under your APIHarbor service -> Variables.

# --- Databases: use Railway REFERENCE variables (internal, fast, no SSL hassle) ---
DB_CONNECTION_URI=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# --- Core secrets (generate once, keep stable) ---
# openssl rand -hex 16
ENCRYPTION_KEY=<32-hex-chars>
# openssl rand -base64 32
AUTH_SECRET=<base64-secret>

# --- Serving ---
NODE_ENV=production
STANDALONE_MODE=true
HOST=0.0.0.0
# PORT is injected by Railway automatically
# After you generate a domain, set this to it:
SITE_URL=https://<your-service>.up.railway.app

# --- Email (Gmail / Workspace) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=<your-smtp-user>
SMTP_PASSWORD=<gmail-app-password-no-spaces>
SMTP_FROM_ADDRESS=<your-smtp-user>
SMTP_FROM_NAME=APIHarbor

# --- Google Sign-In ---
CLIENT_ID_GOOGLE_LOGIN=<google-client-id>
CLIENT_SECRET_GOOGLE_LOGIN=<google-client-secret>
# In Google Cloud Console, add this Authorized redirect URI:
#   https://<your-service>.up.railway.app/api/v1/sso/google

# --- Optional: raise the 30-key Free-tier cap for a private/Enterprise deploy ---
# API_KEYS_PER_PROJECT_LIMIT=1000

TELEMETRY_ENABLED=false
