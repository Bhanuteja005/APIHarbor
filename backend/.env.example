# ===================== APIHarbor backend environment =====================
# Copy to .env for local dev. In production (Railway) set these as service
# variables instead of committing a file.

# --- Core (REQUIRED) -------------------------------------------------------
NODE_ENV=production

# Platform data-encryption key — 16-byte hex (32 hex chars).
#   generate:  openssl rand -hex 16
ENCRYPTION_KEY=

# JWT signing secret — 32-byte base64.
#   generate:  openssl rand -base64 32
AUTH_SECRET=

# PostgreSQL connection string (main DB).
#   Railway:   DB_CONNECTION_URI=${{Postgres.DATABASE_URL}}
DB_CONNECTION_URI=postgres://user:pass@host:5432/apiharbor

# Redis connection string (queues, caching, event bus).
#   Railway:   REDIS_URL=${{Redis.REDIS_URL}}
REDIS_URL=redis://host:6379

# Public URL the browser uses to reach the app.
#   Railway:   SITE_URL=https://<your-service>.up.railway.app
SITE_URL=http://localhost:3000

# --- Serving --------------------------------------------------------------
# Serve the bundled SPA from the API server (set automatically in the Docker image).
STANDALONE_MODE=true
HOST=0.0.0.0
PORT=4000

# --- Optional: email (enables verification / password reset / invites) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=APIHarbor

# --- Optional: Google sign-in (SSO) ---------------------------------------
CLIENT_ID_GOOGLE_LOGIN=
CLIENT_SECRET_GOOGLE_LOGIN=

# --- Optional: API-key tier limit -----------------------------------------
# Free tier caps API keys per project at 30. Raise for private/Enterprise deploys.
# API_KEYS_PER_PROJECT_LIMIT=30

# --- Optional: telemetry (off by default here) ----------------------------
TELEMETRY_ENABLED=false
OTEL_TELEMETRY_COLLECTION_ENABLED=false

# --- Optional: dedicated audit-log database -------------------------------
# Leave blank to store audit logs in the main DB.
# AUDIT_LOGS_DB_CONNECTION_URI=
