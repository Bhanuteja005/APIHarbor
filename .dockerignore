# Not part of the backend image (frontend deploys on Vercel)
frontend/
dashboard-ui/

# Dependencies & build output (reinstalled/rebuilt inside the image)
**/node_modules/
backend/dist/
backend/frontend-build/

# Local env & secrets — NEVER ship these; set env vars in Railway instead
**/.env
**/.env.*
!**/.env.example

# Tooling / VCS / editor noise
.git/
.github/
**/.turbo/
**/coverage/
**/*.log
**/.DS_Store
.claude/
scratchpad/
