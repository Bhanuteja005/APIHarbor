# APIHarbor frontend environment variables.
#
# All of these are OPTIONAL and read at BUILD TIME by Vite (they must be
# prefixed with VITE_ to be exposed to the browser bundle). Copy to `.env`
# only if you need to override a default.
#
# In the default single-image deploy the backend serves the SPA on the same
# origin, so none of these are required to run the app.

# --- Backend API location -----------------------------------------------------
# Base URL of the backend API. Leave EMPTY for the single-image / STANDALONE_MODE
# deploy and for local dev (the Vite dev server proxies /api -> localhost:4000).
# Set this ONLY when the frontend is served from a different origin than the
# backend (e.g. a standalone frontend service). Example:
#   VITE_API_URL=https://apiharbor-production.up.railway.app
# NOTE: a cross-origin backend also requires (a) relaxing the CSP connect-src in
# index.html to allow that origin and (b) enabling CORS on the backend.
VITE_API_URL=

# --- Optional third-party integrations / analytics ----------------------------
# VITE_POSTHOG_API_KEY=
# VITE_POSTHOG_HOST=https://app.posthog.com
# VITE_INTERCOM_ID=
# VITE_CAPTCHA_SITE_KEY=
# VITE_TELEMETRY_CAPTURING_ENABLED=false
# VITE_INFISICAL_PLATFORM_VERSION=

# --- Dev server ---------------------------------------------------------------
# Comma-separated extra hostnames the Vite dev/preview server may be accessed by.
# VITE_ALLOWED_HOSTS=
